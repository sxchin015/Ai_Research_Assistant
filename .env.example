# ============================================================
# AI Research Assistant - Environment Variables
# ============================================================
# Copy this file to .env and fill in your Groq key.

# ── REQUIRED: Groq API Key (FREE, no credit card) ────────────
# 1. Go to: https://console.groq.com
# 2. Sign up with email (no credit card needed)
# 3. Click "API Keys" → "Create API Key"
# 4. Paste it below:
GROQ_API_KEY=gsk_your_key

# ── OPTIONAL: Groq model (all are FREE) ──────────────────────
# Current active Groq models (as of 2026):
#   llama-3.3-70b-versatile   ← DEFAULT (best quality)
#   llama-3.1-8b-instant      ← fastest option
#   llama-3.1-70b-versatile   ← alternative 70b
#   mixtral-8x7b-32768        ← great for long documents
#   gemma2-9b-it              ← Google Gemma, also free
#
GROQ_MODEL=llama-3.3-70b-versatile

# ── OPTIONAL: Embedding model (local, no key needed) ─────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── OPTIONAL: SerpAPI (leave empty = uses free DuckDuckGo) ───
SERPAPI_KEY=

# ── OPTIONAL: RAG tuning ──────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RESULTS=4
MIN_RELEVANCE_SCORE=0.30
